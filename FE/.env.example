# Copy this file to `.env` and fill in your actual API key.
# `.env` is gitignored and stays local — never commit it.
#
# Used by: `npm run gen-dict` (auto-translate dictionary for tooltip).
#
# Pick ONE provider — script auto-detects whichever is set:

# Google Gemini (recommended, free tier 1500 req/day)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (free, Llama 3.3 70B, 14400 req/day)
# Get key: https://console.groq.com/keys
# GROQ_API_KEY=

# OpenRouter (limited free models)
# Get key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=
