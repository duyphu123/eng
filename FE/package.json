{
  "name": "eng-toeic",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "design:lint": "design.md lint --format text DESIGN.md",
    "design:export:tailwind": "design.md export --format tailwind DESIGN.md",
    "design:export:dtcg": "design.md export --format dtcg DESIGN.md",
    "design:tokens": "node scripts/gen-tokens.mjs",
    "gen-audio": "node scripts/gen-audio.mjs",
    "gen-dict": "node scripts/gen-dict.mjs",
    "deploy": "ng build --base-href \"/eng/\" --configuration production && angular-cli-ghpages --dir=dist/eng-toeic/browser"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@floating-ui/dom": "^1.7.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular/cli": "^17.3.17",
    "@angular/compiler-cli": "^17.3.0",
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/design.md": "^0.1.1",
    "@types/jasmine": "~5.1.0",
    "angular-cli-ghpages": "^3.0.3",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "msedge-tts": "^2.0.5",
    "typescript": "~5.4.2"
  }
}
