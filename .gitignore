# ============================================================
#  Monorepo root .gitignore  (covers FE + BE)
#  Patterns WITHOUT a leading slash match at ANY depth —
#  e.g. `node_modules/` also matches `FE/node_modules/`.
#  Each app may keep its own .gitignore for extra rules.
# ============================================================

# ---- Dependencies ----
node_modules/

# ---- Build output (FE) ----
dist/
/out-tsc
/tmp
.angular/cache/
.sass-cache/
/coverage

# ---- Backend: Spring Boot (Maven / Gradle) ----
target/
build/
*.class
hs_err_pid*
replay_pid*

# ---- Env / secrets ----
.env
.env.*
!.env.example

# ---- IDE / editor ----
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.history/

# ---- Claude Code (machine-specific overrides) ----
**/.claude/settings.local.json

# ---- GitNexus (machine-specific index + MCP config) ----
.gitnexus/
.mcp.json

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
npm-debug.log*
yarn-error.log
